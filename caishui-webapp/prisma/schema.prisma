// prisma/schema.prisma
// 财税知识库问答 WebApp — 数据模型（架构 v2.1 第三章）
// 向量索引、JSONB GIN 索引、ingest_tasks 表通过 prisma/migrations 中的原始 SQL 创建。

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────
// 枚举定义
// ─────────────────────────────────────────────

enum ProcessingStatus {
  PENDING // 已上传，等待处理
  PROCESSING // 正在清洗中
  COMPLETED // 清洗完成，已入库（仅表示技术状态）
  FAILED // 清洗失败
}

enum DocType {
  REGULATION // 法规（法律、条例、规章）
  ANNOUNCEMENT // 公告（税务总局/地方公告）
  NOTICE // 通知
  INTERPRETATION // 解读（官方解读、答疑函）
  CASE // 案例（稽查案例、判例）
  GUIDE // 操作指引（申报指南等）
}

enum FileType {
  PDF
  MD
  XLSX
  CSV
}

enum EmbeddingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RetrievalStatus {
  RETRIEVABLE
  WITHDRAWN
}

enum AnswerStatus {
  GENERATING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────
// SourceDocument 表：一个上传文件 + 一个来源渠道的不可变来源单元（见 ADR-0001）
// 法律权威（文号/生效日期/效力层级）作为其元数据字段，不单独建表
// ─────────────────────────────────────────────

model SourceDocument {
  id        String   @id @default(cuid())
  title     String // 文档标题
  file_name String // 原始文件名
  file_type FileType // 文件类型枚举（PDF / MD / XLSX / CSV）
  file_size Int // 文件大小（字节）
  file_path String? // 存储路径（本地或 COS 对象键）
  file_hash String // SHA-256；同内容不同 Source Channel 仍是不同 Source Document

  // 处理状态（仅表示入库/清洗流程，不表示法律效力）
  processing_status ProcessingStatus @default(PENDING)
  retrieval_status  RetrievalStatus  @default(RETRIEVABLE) // 是否允许其解析内容参与当前检索
  error_message     String? // 处理失败时记录错误信息

  // 财税专用字段
  doc_type       DocType? // 文档类型
  doc_number     String? // 文号（如"财税〔2023〕X号"）
  publish_date   DateTime? // 官方发布日期，不等于上传/抓取/生效日期
  effective_date DateTime? // 生效日期
  expire_date    DateTime? // 失效日期（null 表示仍有效）
  jurisdiction   String? // 管辖地（"全国" | "上海市" | "广东省" 等）
  issuing_body   String? // 发文机关（"国家税务总局" 等）
  source_channel String? // 采集/发布渠道名称，如"国家税务总局官网"
  authority_rank Int? // 效力层级（法律100…衍生参考30；null表示未知）

  // 时间戳
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  processed_at DateTime? // 清洗完成时间

  // 关联
  chunks KnowledgeChunk[]

  @@index([processing_status])
  @@index([file_hash, source_channel])
  @@index([retrieval_status])
  @@index([doc_type])
  @@index([publish_date])
  @@index([effective_date])
  @@index([jurisdiction])
  @@index([authority_rank])
  @@map("source_documents")
}

// ─────────────────────────────────────────────
// KnowledgeChunk 表：切块后的知识单元
// ─────────────────────────────────────────────

model KnowledgeChunk {
  id                String   @id @default(cuid())
  pipeline_chunk_id String // data-pipeline 生成的 SHA256(file_hash + chunk_index)，用于定位来源位置
  document_id       String
  // 关系字段名保留为 document（导航用）；外键列保留 document_id（见 ADR-0001，避免大范围改名）
  document          SourceDocument @relation(fields: [document_id], references: [id], onDelete: Restrict)

  // 内容
  content      String // chunk 原文
  content_hash String // chunk 内容 SHA-256（去重用）
  chunk_index  Int // 在文档中的顺序索引（从 0 开始）
  chunk_type   String @default("text") // "text" | "table" | "image_caption"

  // 向量字段（通过原始 SQL 迁移创建索引）
  // 注意：Prisma 使用 Unsupported 声明，实际写入通过 $executeRaw 完成
  // 维度锁定 1024（BAAI/bge-large-zh-v1.5 @ 硅基流动），见 ADR-0006
  embedding                 Unsupported("vector(1024)")? // 生产检索向量；仅 verified chunk 可非空
  embedding_status          EmbeddingStatus              @default(PENDING) // 向量生成技术状态，与核验状态相互独立
  embedding_error           String?
  embedding_identity        String? // SHA-256(document_id + content_hash + model + dimension)
  embedding_model           String?
  embedding_dimension       Int?
  embedding_attempts        Int                          @default(0)
  embedding_last_attempt_at DateTime?

  // 财税专用字段（冗余自 Document，加速检索时过滤）
  publish_date         DateTime?
  effective_date       DateTime?
  expire_date          DateTime?
  jurisdiction         String?
  source_channel       String?
  doc_type             DocType?
  authority_rank       Int?
  is_current_version   Boolean         @default(true) // 是否为当前版本；MVP 默认 true
  version_of_provision String? // 同一权威条款的版本归并键；MVP 可为空
  verification_status  String          @default("unverified") // "verified" | "unverified" | "rejected" | "disputed"
  verification_method  String? // "auto" | "human" | "seed"
  verified_by          String? // 规则名、审核人或 seed 导入批次
  verified_at          DateTime?
  verification_notes   String?
  provision_type       String          @default("operative") // operative | delegating | definitional | procedural | sunset
  answer_role          String? // substantive_rule | authority_delegation | rule_status
  retrieval_status     RetrievalStatus @default(RETRIEVABLE) // 撤出检索不改变 verification_status
  withdrawn_at         DateTime?
  withdrawn_by         String?
  withdrawal_reason    String?

  // 元数据 JSONB 字段
  metadata Json @default("{}")

  // 时间戳
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([document_id])
  @@index([pipeline_chunk_id])
  @@index([chunk_index])
  @@index([jurisdiction])
  @@index([publish_date])
  @@index([effective_date])
  @@index([authority_rank])
  @@index([is_current_version])
  @@index([verification_status])
  @@index([provision_type])
  @@index([embedding_status])
  @@index([retrieval_status])
  // 注意：向量索引及 Current Version 部分唯一索引通过原始 SQL 创建，
  // 见 prisma/migrations/manual/*。
  @@map("knowledge_chunks")
}

// ─────────────────────────────────────────────
// Answer / Citation / Audit
// ─────────────────────────────────────────────

model Answer {
  id                         String       @id @default(cuid())
  conversation_id            String
  original_question          String
  retrieval_query            String? // Standalone Query；需要澄清时可为空
  context_snapshot           Json? // 生成 retrieval_query 时使用的最近对话上下文
  status                     AnswerStatus @default(GENERATING)
  draft_text                 String? // 流式临时缓冲，不作为正式答案
  answer_text                String? // 仅 COMPLETED 时非空
  model                      String // 如 "deepseek-chat"
  prompt_template_version    String // 如 "v1" 或模板内容 hash
  coverage_evidence_snapshot Json // 回答生成时的 RetrievalCoverageEvidence
  started_at                 DateTime     @default(now())
  completed_at               DateTime?
  failed_at                  DateTime?
  error_code                 String? // client_disconnected | model_error | grounding_failed | persistence_error
  error_message              String?

  citations AnswerCitation[]

  @@index([conversation_id])
  @@index([status])
  @@index([started_at])
  @@map("answers")
}

model AnswerCitation {
  id         String   @id @default(cuid())
  answer_id  String
  answer     Answer   @relation(fields: [answer_id], references: [id], onDelete: Restrict)
  chunk_id   String // 回答生成时引用的 chunk ID；不使用外键级联删除
  snapshot   Json // 不可变：文号、标题、证据片段、content_hash、来源位置、回答时间、截断标记
  created_at DateTime @default(now())

  annotations CitationAnnotation[]

  @@index([answer_id])
  @@index([chunk_id])
  @@map("answer_citations")
}

model CitationAnnotation {
  id                 String         @id @default(cuid())
  answer_citation_id String
  answer_citation    AnswerCitation @relation(fields: [answer_citation_id], references: [id], onDelete: Restrict)
  annotation_type    String // source_withdrawn | content_error | source_removed
  message            String
  created_at         DateTime       @default(now())
  resolved_at        DateTime?

  @@index([answer_citation_id])
  @@map("citation_annotations")
}

model AuditEvent {
  id          String   @id @default(cuid())
  actor_id    String
  action      String // upload | ingest_started | human_verified | source_withdrawn | source_restored | hard_deleted | seed_added 等
  target_type String // SourceDocument | KnowledgeChunk | AnswerCitation | SeedCorpus 等
  target_id   String
  old_state   Json?
  new_state   Json?
  reason      String?
  payload     Json     @default("{}")
  created_at  DateTime @default(now())

  @@index([actor_id])
  @@index([action])
  @@index([target_type, target_id])
  @@index([created_at])
  @@map("audit_events")
}
