# ─────────────────────────────────────────────
# caishui-webapp 环境变量示例（提交到 Git）
# 复制为 .env.local 并填入真实值；.env.local 不得提交
# ─────────────────────────────────────────────

# PostgreSQL（与 data-pipeline 共享同一实例）
DATABASE_URL="postgresql://caishui:localdev_password@localhost:5432/caishui_db"
# 并发基线：30 并发问答最低连接池
PRISMA_CONNECTION_POOL_MAX=30

# Python 清洗微服务地址
DATA_PIPELINE_URL="http://localhost:8000"
# WebApp → Pipeline HMAC 共享密钥；两端必须完全一致，生产环境使用高熵随机值。
PIPELINE_SHARED_SECRET=""

# DeepSeek API（仅 Chat / 生成）
DEEPSEEK_API_KEY=""
# 开发前必须在 DeepSeek 控制台确认实际限额后填写
DEEPSEEK_RPM=60
DEEPSEEK_MAX_CONCURRENCY=10

# Embedding 提供商（独立于 DeepSeek，见 ADR-0006）：硅基流动 + BAAI/bge-large-zh-v1.5（1024维）
EMBEDDING_BASE_URL="https://api.siliconflow.cn/v1"
EMBEDDING_API_KEY=""
EMBEDDING_MODEL="BAAI/bge-large-zh-v1.5"
EMBEDDING_DIMENSION=1024

# 检索 / 答案配置
PROMPT_TEMPLATE_VERSION="v1"
# 仅为原型初值；生产值必须由标注测试集校准，范围 [0,1]
EVIDENCE_SUFFICIENT_THRESHOLD=0.55

# 全局覆盖范围
COVERAGE_START_DATE="2000-01-01"
CHINATAX_LAST_SUCCESSFUL_SYNC=""
MOF_LAST_SUCCESSFUL_SYNC=""
GOVCN_LAST_SUCCESSFUL_SYNC=""

# 身份信任边界（安全默认）。本地保持 false：忽略 X-User-* 头，使用下方 MVP_ACTOR_*。
# 仅在部署于受信任内网代理之后（代理已剥离客户端自带的同名头）才设为 true。
TRUST_PROXY_AUTH=false
# TRUST_PROXY_AUTH=true 时必填。受信任代理必须注入 X-Proxy-Shared-Secret，WebApp 会校验该值。
PROXY_SHARED_SECRET=""

# MVP 身份（本地单人开发；TRUST_PROXY_AUTH=false 时生效）
MVP_ACTOR_ID="dev"
MVP_ACTOR_ROLES="admin,reviewer,viewer"
